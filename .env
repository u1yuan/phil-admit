# ============================================
# PhilAdmit — Environment Variables
# ============================================

# Database (PostgreSQL -> SQLite for easy local run)
DATABASE_URL="file:./dev.db"

# NextAuth.js
NEXTAUTH_SECRET="your-nextauth-secret-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# File Storage Provider — set to "supabase" or "s3"
STORAGE_PROVIDER="supabase"

# Supabase (if STORAGE_PROVIDER=supabase)
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# AWS S3 (if STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
AWS_REGION="ap-southeast-1"

# Email — Resend
RESEND_API_KEY=""

# SMS — Semaphore PH (TODO: configure in production)
SEMAPHORE_API_KEY=""
SEMAPHORE_SENDER_NAME="PhilAdmit"

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_ENV="development"
